# LogDB account-scoped API key. REQUIRED. Kept server-side only.
LOGDB_API_KEY=pk_your_key_here

# Optional — stamped onto every log forwarded through this relay.
LOGDB_APPLICATION=my-nextjs-app
LOGDB_ENVIRONMENT=production

# Optional — skip discovery by pinning the reader/writer endpoints.
# LOGDB_SERVICE_URL=https://your-tenant.logdb.site/grpc-logger
# LOGDB_READER_SERVICE_URL=https://your-tenant.logdb.site/grpc-server

# Optional — comma-separated CORS allowlist. Defaults to "*".
# LOGDB_ALLOWED_ORIGINS=https://my-app.vercel.app,https://staging.my-app.com
