# Your LogDB relay endpoint. Deploy the Supabase Edge Function from
# @logdbhq/web/templates/supabase-edge-function/ and point at it here.
# Works with any relay — Supabase, Cloudflare Worker, Next.js API route, etc.
VITE_LOGDB_RELAY_URL=https://<your-project-ref>.supabase.co/functions/v1/logdb-relay

# Optional: stamped onto every log this app writes.
VITE_APP_NAME=logdb-react-dashboard
